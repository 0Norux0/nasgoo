# =====================================================================
# .env.testing.example — Phase 12.3 v12.3.2
# =====================================================================
#
# Purpose: give developers a driver-independent way to run the test
# suite without having to install php-pgsql on every workstation.
#
# The developer's v12.3.1 review confirmed their PHP has:
#   ✓ PDO, pdo_mysql, pdo_sqlite
#   ✗ pgsql, pdo_pgsql (NOT installed — this is what blocked v12.3.1 tests)
#   ✗ sodium         (NOT installed — required for license cryptography;
#                     see `php artisan license:doctor` to detect this)
#
# The default block below (Option C, SQLite in-memory) uses ONLY
# pdo_sqlite, so tests boot cleanly on the reported environment without
# installing anything new. Switch to Option A only after installing
# pdo_pgsql. Switch to Option B if you prefer MySQL.
#
# Usage:
#   cp .env.testing.example .env.testing
#   (edit the chosen block below)
#   php artisan test
#
# Laravel loads .env.testing during tests, and its values override the
# `<env>` entries in phpunit.xml.
#
# =====================================================================

APP_ENV=testing
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

BCRYPT_ROUNDS=4

CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
MAIL_MAILER=array

# ─────────────────────────────────────────────────────────────────────
# CHOOSE ONE database block below.
# ─────────────────────────────────────────────────────────────────────

# Option A — PostgreSQL (matches CI, matches production if you use pgsql)
# Requires: sudo apt-get install php8.3-pgsql (or php-pgsql for your version)
# Verify:   php -m | grep pdo_pgsql
#DB_CONNECTION=pgsql
#DB_HOST=127.0.0.1
#DB_PORT=5432
#DB_DATABASE=marketplace_testing
#DB_USERNAME=postgres
#DB_PASSWORD=postgres

# Option B — MySQL / MariaDB (developer's environment supports this)
# Verify:   php -m | grep pdo_mysql   (should show output)
#DB_CONNECTION=mysql
#DB_HOST=127.0.0.1
#DB_PORT=3306
#DB_DATABASE=marketplace_testing
#DB_USERNAME=root
#DB_PASSWORD=

# Option C — SQLite in-memory (default; fastest, zero external services)
# Verify:   php -m | grep pdo_sqlite   (should show output)
DB_CONNECTION=sqlite
DB_DATABASE=:memory:

# ─────────────────────────────────────────────────────────────────────
# License-specific overrides for tests
# ─────────────────────────────────────────────────────────────────────

LICENSE_ENFORCEMENT_ENABLED=false
LICENSE_PUBLIC_KEY=
LICENSE_REQUIRE_DOMAIN_MATCH=false
LICENSE_REQUIRE_FINGERPRINT_MATCH=false
LICENSE_FAIL_CLOSED=false

# ─────────────────────────────────────────────────────────────────────
# Notes
# ─────────────────────────────────────────────────────────────────────
#
# 1. The license test suite uses `Config::set(...)` inside individual
#    tests to enable enforcement / binding as needed. The defaults above
#    are safe baselines that let ALL tests boot cleanly.
#
# 2. If you see `could not find driver (Connection: pgsql, ...)` when
#    running the suite, run `php artisan license:doctor` — it will tell
#    you EXACTLY which driver is missing and how to install it.
#
# 3. This file is a template. Do NOT commit `.env.testing` itself — it's
#    in `.gitignore`.
#
# 4. Preflight check any time: `php artisan license:doctor`. That
#    command tests ext-sodium, PDO driver, LICENSE_PUBLIC_KEY, license
#    tables, storage writability, cache, and manager status.
