# =====================================================================
# Application
# =====================================================================
APP_NAME="Marketplace"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Kuwait

# =====================================================================
# Localization (Phase 0 supports en + ar; ur prepared for later)
# =====================================================================
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
SUPPORTED_LOCALES=en,ar,ur
DEFAULT_CURRENCY=KWD
SUPPORTED_CURRENCIES=KWD,USD,AED,PKR

# =====================================================================
# Logging
# =====================================================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# =====================================================================
# Database (PostgreSQL)
# =====================================================================
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=marketplace
DB_USERNAME=marketplace
DB_PASSWORD=secret

# =====================================================================
# Cache, Queue, Session, Redis
# =====================================================================
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
CACHE_STORE=redis
CACHE_PREFIX=

# =====================================================================
# v3.3 — Session cookie / CSRF
#
# These defaults are tuned for the standard Docker dev setup (browser
# hits http://localhost:8000). They prevent the most common cause of
# 419 "Page Expired" errors: a cookie that the browser refuses to send
# back because of a domain/secure/samesite mismatch.
#
# Production (HTTPS, real domain) overrides:
#   SESSION_DOMAIN=.your-domain.tld
#   SESSION_SECURE_COOKIE=true
#   SANCTUM_STATEFUL_DOMAINS=your-domain.tld
# =====================================================================
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
SESSION_PATH=/
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,127.0.0.1,127.0.0.1:8000

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# =====================================================================
# Mail
# =====================================================================
# Phase 7 v7.5 — default to the 'log' driver so fresh local installs can
# register users without any external mail service. Verification emails
# are written to storage/logs/laravel.log; copy the signed URL from there
# to verify accounts during local testing.
#
# To use Mailpit (only useful if you started the Docker stack — Mailpit
# is included as a service in docker-compose.yml), switch to:
#
#   MAIL_MAILER=smtp
#   MAIL_HOST=mailpit
#   MAIL_PORT=1025
#
# Mailpit UI is at http://localhost:8025
#
# For production, configure your real SMTP / SES / Mailgun credentials.
# Phase 7 v7.5 also wraps the verification-email send in a try/catch
# inside the User model + RegisterController, so even a misconfigured
# mailer in production will NOT crash registration — the failure is
# logged and the user still gets their account.
MAIL_MAILER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@marketplace.test"
MAIL_FROM_NAME="${APP_NAME}"

# =====================================================================
# Search (Meilisearch) — Phase 0 ships without scout package.
# These are pre-configured for Phase 3 when scout + meilisearch-php
# are added. The Meilisearch container is already running and the
# Phase 0 health check pings it directly via curl.
# =====================================================================
# SCOUT_DRIVER=meilisearch
# SCOUT_QUEUE=true
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=masterKey

# =====================================================================
# Storage
# Local for development. Switch FILESYSTEM_DISK=r2 in production.
# =====================================================================
# Cloudflare R2 (production)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=marketplace-media
R2_ENDPOINT=
R2_URL=

# AWS S3 (alternative)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# =====================================================================
# Payment Gateways (placeholders for Phase 4)
# =====================================================================
TAP_SECRET_KEY=
TAP_PUBLIC_KEY=
TAP_WEBHOOK_SECRET=

MYFATOORAH_API_KEY=
MYFATOORAH_BASE_URL=https://apitest.myfatoorah.com
MYFATOORAH_WEBHOOK_SECRET=

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_MODE=sandbox

# =====================================================================
# Marketplace defaults (per approved decisions)
# =====================================================================
MARKETPLACE_DEFAULT_RETURN_WINDOW_DAYS=7
MARKETPLACE_DEFAULT_COMMISSION_BASIC=30
MARKETPLACE_DEFAULT_COMMISSION_STANDARD=20
MARKETPLACE_DEFAULT_COMMISSION_PROFESSIONAL=10
MARKETPLACE_GUEST_BROWSING=true
MARKETPLACE_GUEST_CHECKOUT=false

# =====================================================================
# Vite
# =====================================================================
VITE_APP_NAME="${APP_NAME}"
