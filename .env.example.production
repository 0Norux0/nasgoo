# =====================================================================
# Kuwait Marketplace — PRODUCTION .env example
# =====================================================================
#
# Copy this file to `.env` on your PRODUCTION server ONLY.
# Do NOT commit the real .env to Git.
# The development-focused .env.example is unsafe for production
# (APP_DEBUG=true, APP_ENV=local, cookies without secure flag).
# Use this file when preparing a production release.
#
# Every value marked CHANGE_ME_ must be replaced before deployment.
# Every URL and hostname must match your real production infrastructure.
# =====================================================================

# ─── Application ─────────────────────────────────────────────────────
APP_NAME="Marketplace"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com
APP_TIMEZONE=Asia/Kuwait

# ─── Localization ────────────────────────────────────────────────────
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
SUPPORTED_LOCALES=en,ar,ur
DEFAULT_CURRENCY=KWD
SUPPORTED_CURRENCIES=KWD,USD,AED,PKR

# ─── Logging ─────────────────────────────────────────────────────────
# LOG_LEVEL=error in production keeps disk quiet; raise to warning or
# info temporarily during incidents. Never leave debug enabled here.
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=error
LOG_DAILY_DAYS=30

# ─── Database ────────────────────────────────────────────────────────
# DB_HOST=127.0.0.1 assumes DB and app on the same host or a private
# subnet. Never expose port 3306 to 0.0.0.0/0.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_production_database
DB_USERNAME=your_production_database_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── Cache / Session / Queue ─────────────────────────────────────────
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
# SESSION_SECURE_COOKIE=true requires HTTPS. Do not enable until your
# production APP_URL is served over TLS or sessions will silently fail.
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# ─── Redis ───────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_DB=0
REDIS_CACHE_DB=1

# ─── Mail ────────────────────────────────────────────────────────────
# For real production traffic use a transactional provider (SES, Postmark,
# Sendgrid, Mailgun) — not a shared SMTP relay. Keep credentials in a
# secrets manager if your platform provides one.
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=CHANGE_ME_SMTP_PASSWORD
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@your-domain.com
MAIL_FROM_NAME="${APP_NAME}"

# ─── Filesystem / Storage ────────────────────────────────────────────
# For production, prefer S3-compatible object storage (S3, Wasabi, R2,
# Backblaze B2) over local disk. Local disk works but complicates
# backup coordination (see PHASE_12_DATABASE_BACKUP_PLAN.md §8).
FILESYSTEM_DISK=public
# Uncomment and configure if switching to s3:
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=CHANGE_ME_S3_KEY_ID
# AWS_SECRET_ACCESS_KEY=CHANGE_ME_S3_SECRET
# AWS_DEFAULT_REGION=me-south-1
# AWS_BUCKET=your-production-bucket
# AWS_URL=https://your-cdn-domain.example
# AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Meilisearch ─────────────────────────────────────────────────────
# Phase 6 search backend. If you use Meilisearch in production, restrict
# the master key to server-side only — never expose it to the browser.
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=CHANGE_ME_MEILISEARCH_MASTER_KEY

# ─── Broadcast / Pusher (optional) ───────────────────────────────────
BROADCAST_CONNECTION=null
# If enabling websocket features, set:
# BROADCAST_CONNECTION=pusher
# PUSHER_APP_ID=CHANGE_ME
# PUSHER_APP_KEY=CHANGE_ME
# PUSHER_APP_SECRET=CHANGE_ME
# PUSHER_HOST=
# PUSHER_PORT=443
# PUSHER_SCHEME=https
# PUSHER_APP_CLUSTER=mt1

# ─── Payment gateways (Kuwait region) ────────────────────────────────
# KNET/MyFatoorah/Tap — configure per your merchant agreements.
# Never commit real merchant IDs or API keys.
PAYMENT_KNET_MERCHANT_ID=CHANGE_ME_KNET_MERCHANT_ID
PAYMENT_KNET_SECRET=CHANGE_ME_KNET_SECRET
PAYMENT_KNET_URL=https://your-knet-endpoint.example

# ─── Vite / build-time ───────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"

# ─── Vendor Intelligence (Phase 11B.4) ───────────────────────────────
# These override the runtime SiteSettings when set. Prefer to configure
# thresholds via /admin/site-settings/vendor_intelligence in the admin
# UI (which persists to the settings table and is cache-invalidated on
# save) rather than baking values into .env.
# VENDOR_INTELLIGENCE_ENABLED=true

# ─── License activation (Phase 12.3) ─────────────────────────────────
# Ed25519-signed license token verification. When enforcement is enabled,
# the marketplace requires an activated license (via /admin/license or
# `php artisan license:activate`). See docs/PHASE_12_3_OWNER_INSTRUCTIONS.md.
#
# LICENSE_ENFORCEMENT_ENABLED=true only after:
#   1. You have generated a keypair (see tools/license-generator/README.md)
#   2. You have installed the public key below
#   3. You have run `php artisan migrate` to create license tables
#   4. You have activated a valid token
#
# Default is `false` so a fresh install boots without a license.
LICENSE_ENFORCEMENT_ENABLED=false

# Base64-encoded Ed25519 public key (32 raw bytes → 44 chars base64).
# NEVER commit a real private key. This value is the public verification key
# only — safe to include in .env after the owner supplies it.
LICENSE_PUBLIC_KEY=

# Default license duration in days (60 per Phase 12.3 §4).
LICENSE_DEFAULT_DURATION_DAYS=60

# Grace period in days after expiry during which the app still passes
# requests (with a red banner shown to admins). 0 = hard expiry.
LICENSE_GRACE_DAYS=0

# Public storefront visibility on expiry. Default false = storefront stays
# visible; only authenticated + admin + checkout routes get blocked.
LICENSE_BLOCK_PUBLIC_STOREFRONT=false

# Bind the token to the request's Host header (recommended in production).
LICENSE_REQUIRE_DOMAIN_MATCH=true

# v12.3.1: domain used for license binding in CLI/queue contexts where no
# HTTP request is bound (artisan commands, queue workers). Leave empty to
# fall back to APP_URL. Set this if APP_URL differs from the licensed
# domain (unusual but possible in multi-domain deployments).
LICENSE_DOMAIN=

# v12.3.1: treat www.example.com and example.com as equivalent for
# domain-binding. Default true.
LICENSE_ALLOW_WWW_ALIAS=true

# Bind the token to this server's fingerprint (see `php artisan license:fingerprint`).
# Leave false unless the token was generated WITH a fingerprint claim.
LICENSE_REQUIRE_FINGERPRINT_MATCH=false

# License state cache TTL in seconds (300 = 5 min).
LICENSE_CACHE_TTL_SECONDS=300

# When enforcement=true but no key or activation exists, block requests
# (true = fail-closed for production, false = fail-open for staging).
LICENSE_FAIL_CLOSED=true

# =====================================================================
# Pre-deployment checklist
# =====================================================================
# Before pushing this file (renamed to .env) to production:
#
#   [ ] APP_ENV=production
#   [ ] APP_DEBUG=false
#   [ ] APP_URL is your real HTTPS domain
#   [ ] APP_KEY is set (run: php artisan key:generate --show, then paste)
#   [ ] Every CHANGE_ME_ placeholder replaced
#   [ ] DB credentials point at the production database, NOT a dev copy
#   [ ] Redis password set (not the default empty string)
#   [ ] Mail credentials use a transactional provider account
#   [ ] SESSION_SECURE_COOKIE=true (requires HTTPS to work)
#   [ ] `.env` NOT committed to Git (verify .gitignore contains .env)
#   [ ] File permissions: 0640, owned by app user, readable by web-server group
#
# See PHASE_12_DATABASE_SETUP_GUIDE.md and
# PHASE_12_DATABASE_SECURITY_CHECKLIST.md for the full pre-launch flow.
# =====================================================================
